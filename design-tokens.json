{
  "$meta": {
    "name": "手冲陪学 · POUR.LOG Design System",
    "theme": "森林绿 (Forest Green)",
    "source": "手冲陪学.dc.html",
    "description": "实验室 / 极客数据化风格。等宽字体做元信息与数据、黑体做标题正文；直角描边、单一强调绿、克制的红作警示。"
  },
  "color": {
    "accent":      { "value": "#3f6b45", "desc": "主强调色 · 森林绿 · 主按钮/进度/激活态/数据条" },
    "accent-light":{ "value": "#8fb18a", "desc": "强调色浅调 · 深底上的品牌字/次级强调" },
    "ink":         { "value": "#1c231d", "desc": "墨色 · 深底容器/主文字/次级按钮底" },
    "ink-fg":      { "value": "#e9ede6", "desc": "墨底之上的前景字" },
    "app-bg":      { "value": "#edf0ea", "desc": "应用背景 · 底层画布" },
    "card":        { "value": "#f6f8f3", "desc": "卡片/输入框背景" },
    "border":      { "value": "#d5dbcf", "desc": "描边 · 卡片/分隔/网格线" },
    "hot":         { "value": "#c15a3c", "desc": "警示 · 过萃/删除/错误/异常数值" },
    "text": {
      "strong":    { "value": "#2a322a", "desc": "强正文" },
      "body":      { "value": "#4a524a", "desc": "正文" },
      "secondary": { "value": "#6f776d", "desc": "次级文字/说明" },
      "muted":     { "value": "#9aa295", "desc": "元信息/占位/最弱等宽字" },
      "disabled":  { "value": "#b7c1b1", "desc": "禁用/虚线描边" }
    },
    "surface": {
      "track":      { "value": "#e0e5db", "desc": "进度/数据条底槽" },
      "divider":    { "value": "#eef1ec", "desc": "步骤行细分隔" },
      "panel-soft": { "value": "#fbfcfa", "desc": "展开面板浅底" },
      "warn-soft":  { "value": "#fbf3ee", "desc": "警示浅底(未配置态)" }
    }
  },
  "font": {
    "family": {
      "sans": { "value": "'Noto Sans SC', system-ui, sans-serif", "desc": "标题/正文" },
      "mono": { "value": "'JetBrains Mono', monospace", "desc": "元信息/数据/参数/标签" }
    },
    "weight": { "light": 300, "regular": 400, "medium": 500, "bold": 700, "black": 900 },
    "size": {
      "display": { "value": "30px", "weight": 900, "desc": "详情页大标题" },
      "h1":      { "value": "26px", "weight": 900, "desc": "页面标题" },
      "h2":      { "value": "24px", "weight": 900, "desc": "表单标题" },
      "title":   { "value": "20px", "weight": 700, "desc": "卡片主名(豆名)" },
      "lead":    { "value": "18px", "weight": 700, "desc": "区块小标题" },
      "body":    { "value": "14px", "weight": 400, "desc": "正文" },
      "body-sm": { "value": "13px", "weight": 400, "desc": "小正文" },
      "mono-md": { "value": "12px", "weight": 400, "desc": "参数值/按钮/说明" },
      "mono-sm": { "value": "11px", "weight": 400, "desc": "meta 行" },
      "mono-xs": { "value": "10px", "weight": 400, "desc": "小节标签" },
      "mono-2xs":{ "value": "9px",  "weight": 400, "desc": "网格字段名/徽标" }
    },
    "letter-spacing": {
      "brand": { "value": "0.22em", "desc": "品牌 mono 标识" },
      "label": { "value": "0.12em", "desc": "小节 mono 标签" },
      "cta":   { "value": "0.12em", "desc": "主按钮" },
      "meta":  { "value": "0.05em", "desc": "元信息" }
    }
  },
  "radius": {
    "none": { "value": "0px", "desc": "全局直角 · 系统的核心特征,不用圆角" }
  },
  "border": {
    "hairline": { "value": "1px solid #d5dbcf", "desc": "标准描边" },
    "strong":   { "value": "1px solid #1c231d", "desc": "强描边(规格网格外框)" },
    "dashed":   { "value": "1px dashed #b7c1b1", "desc": "新增/录入占位" },
    "active-top":{ "value": "2px solid #3f6b45", "desc": "底部导航激活指示" }
  },
  "space": {
    "screen-x":   { "value": "20px", "desc": "屏幕左右内边距" },
    "card-pad":   { "value": "14px 15px", "desc": "卡片内边距" },
    "gap-tight":  { "value": "6px" },
    "gap":        { "value": "8px" },
    "gap-md":     { "value": "12px" },
    "section":    { "value": "20px", "desc": "区块间距" }
  },
  "shadow": {
    "phone": { "value": "0 30px 70px -20px rgba(28,35,29,.5), 0 8px 24px rgba(28,35,29,.18)", "desc": "设备阴影" },
    "toast": { "value": "0 8px 24px rgba(28,35,29,.3)", "desc": "toast 浮层" }
  },
  "component": {
    "button-primary": { "bg": "#3f6b45", "fg": "#ffffff", "font": "mono", "pad": "15px", "tracking": "0.12em", "radius": "0" },
    "button-dark":    { "bg": "#1c231d", "fg": "#e9ede6", "font": "mono", "pad": "10–13px", "radius": "0" },
    "button-ghost":   { "bg": "transparent", "border": "1px dashed #b7c1b1", "fg": "#6f776d", "font": "mono", "radius": "0" },
    "pill-outline":   { "sel-border": "#3f6b45", "sel-bg": "#f6f8f3", "sel-fg": "#3f6b45", "idle-border": "#d5dbcf", "idle-fg": "#6f776d" },
    "pill-solid":     { "sel-bg": "#3f6b45", "sel-fg": "#ffffff", "idle-border": "#d5dbcf", "idle-fg": "#6f776d" },
    "tag":            { "border": "1px solid #d5dbcf", "fg": "#3f6b45", "font": "mono", "pad": "2px 8px" },
    "badge-best":     { "bg": "#3f6b45", "fg": "#ffffff", "font": "mono", "pad": "2px 6px" },
    "card":           { "bg": "#f6f8f3", "border": "1px solid #d5dbcf", "radius": "0" },
    "spec-grid":      { "outer": "1px solid #1c231d", "inner": "1px solid #d5dbcf", "columns": 3 },
    "data-bar":       { "track": "#e0e5db", "fill": "#3f6b45", "hot": "#c15a3c", "height": "6–8px" }
  },
  "dimensions": {
    "$desc": "六维口感评分 1–5,越高越强",
    "acid":   { "label": "酸",     "lo": "几乎无酸",  "hi": "尖锐刺激" },
    "sweet":  { "label": "甜",     "lo": "寡淡",      "hi": "蜜感明显" },
    "bitter": { "label": "苦",     "lo": "无苦",      "hi": "苦到发涩", "hot-when": ">=4" },
    "clean":  { "label": "干净度", "lo": "浑浊/杂味", "hi": "通透无杂", "hot-when": "<=2" },
    "finish": { "label": "余韵",   "lo": "一喝就没",  "hi": "悠长回甘" },
    "body":   { "label": "醇厚度", "lo": "水感稀薄",  "hi": "饱满挂杯" }
  }
}
